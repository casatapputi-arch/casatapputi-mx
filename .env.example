# =========================================================================
# CONFIGURACION DE CASA TAPPUTI — plantilla versionable
# =========================================================================
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repo (est en .gitignore).
# Para secretos sensibles (mercado pago tokens, SSH passphrases)
# considera usar `pass` (GPG-backed) en su lugar.
# =========================================================================

# === WhatsApp Business ===
WA_PHONE=525563707034
WA_DEFAULT_MSG=Hola Casa Tapputi

# === MercadoPago (cuando se active) ===
# MP_PUBLIC_KEY=
# MP_ACCESS_TOKEN=
# MP_WEBHOOK_URL=

# === Stripe (opcional, clientes fuera de MX) ===
# STRIPE_PUBLIC_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# === Analytics ===
# PLAUSIBLE_DOMAIN=
# GA_MEASUREMENT_ID=

# === Email (cuando se active newsletter) ===
# MAILCHIMP_API_KEY=
# MAILCHIMP_LIST_ID=

# === Cloudflare — DNS del dominio casatapputi.com.mx ===
# Scoped API Token (permisos Zone:Edit + DNS:Edit)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=
